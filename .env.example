# Copy to .env for local `npm run dev`

NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

MONGODB_URI=mongodb://127.0.0.1:27017/price_drop_alert

# Disable Redis / BullMQ workers locally (required on Vercel)
REDIS_ENABLED=false

JWT_SECRET=replace_with_at_least_32_random_characters_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

EMAIL_FROM=no-reply@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
EMAIL_USER=
EMAIL_PASS=

OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_EXPIRY_MINUTES=15

# Vite frontend (optional — defaults to /api proxy in dev)
VITE_API_URL=/api
