{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://price-drop-alert-backend-kda5.onrender.com/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://price-drop-alert-backend-kda5.onrender.com/health"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
